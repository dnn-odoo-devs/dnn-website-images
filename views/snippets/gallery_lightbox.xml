<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_dnn_gallery_lightbox" name="DNN Galería Lightbox">
        <section class="s_dnn_gallery_lightbox dnn_gallery_container pt40 pb40">
            <div class="container">
                <div class="row dnn_gallery_row">
                    <!-- Placeholder inicial para el editor -->
                    <div class="col-lg-3 dnn_gallery_item mb-4">
                        <img src="/web/static/img/placeholder.png" class="img-fluid dnn_fit_contain" alt="Lightbox Placeholder"/>
                    </div>
                </div>
            </div>

            <!-- Estructura del Lightbox (Bootstrap 5 Modal + Carousel) -->
            <div class="modal fade dnn_lightbox_modal" id="dnnLightbox" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
                <div class="modal-dialog modal-dialog-centered modal-xl">
                    <div class="modal-content bg-transparent border-0">
                        <div class="modal-body p-0">
                            <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3 z-index-10" data-bs-dismiss="modal" aria-label="Close"></button>
                            
                            <div id="dnnLightboxCarousel" class="carousel slide" data-bs-ride="false">
                                <div class="carousel-inner dnn_lightbox_inner">
                                    <!-- Los items del carrusel se inyectarán dinámicamente vía JS -->
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target="#dnnLightboxCarousel" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#dnnLightboxCarousel" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>
